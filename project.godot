; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Regolith"
config/description="First-person lunar engineering sandbox: voxel terrain, drill, modular rovers, structural rebuild."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

BeckettRuntime="*uid://dspgi2nxto4e8"
LimboConsole="*res://addons/limbo_console/limbo_console.gd"

[beckett]

effort_schema=2
dock_revealed=true

[debug]

settings/stdout/print_fps=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=2560.0
window/size/window_height_override=1440.0
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/beckett/plugin.cfg", "res://addons/limbo_console/plugin.cfg", "res://addons/proton_scatter/plugin.cfg")

