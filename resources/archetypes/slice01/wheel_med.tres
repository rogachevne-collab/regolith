[gd_resource type="Resource" script_class="ElementArchetype" format=3]

[ext_resource type="Script" path="res://scripts/simulation/resources/build_requirement.gd" id="1_req"]
[ext_resource type="Script" path="res://scripts/simulation/resources/collider_definition.gd" id="2_col"]
[ext_resource type="Script" path="res://scripts/simulation/resources/wheel_definition.gd" id="4_wheel"]
[ext_resource type="Script" path="res://scripts/simulation/resources/structural_mount_pad.gd" id="5_pad"]
[ext_resource type="Script" path="res://scripts/simulation/resources/element_archetype.gd" id="6_arch"]

[sub_resource type="Resource" id="Requirement"]
script = ExtResource("1_req")
resource_id = "mechanism"
amount = 3.0

[sub_resource type="Resource" id="Collider"]
script = ExtResource("2_col")
size = Vector3(0.4, 0.4, 0.4)

[sub_resource type="Resource" id="WheelDefinition"]
script = ExtResource("4_wheel")
radius_m = 0.75
width_m = 0.73
drive_torque_n_m = 160.0
brake_torque_n_m = 420.0
longitudinal_grip = 1.2
lateral_grip = 0.9
slip_stiffness = 900.0
lateral_stiffness = 1100.0
wheel_inertia = 2.5
angular_damping = 0.2
max_angular_speed_rad_s = 120.0
max_steering_angle_rad = 0.4887
steering_response = 2.5
steerable_default = false
forward_axis_face = 5
power_draw_w = 600.0
idle_w = 30.0
requires_socket_tag = "wheel_socket"

[sub_resource type="Resource" id="Mount_plug"]
script = ExtResource("5_pad")
local_face = 2
socket_tag = "wheel_plug"

[resource]
script = ExtResource("6_arch")
archetype_id = "wheel_med"
display_name = "Колесо M"
roles = PackedStringArray("Support", "Actuator")
mass_kg = 45.0
colliders = Array[ExtResource("2_col")]([SubResource("Collider")])
structural_surface_policy = 2
structural_mount_pads = Array[ExtResource("5_pad")]([SubResource("Mount_plug")])
build_requirements = Array[ExtResource("1_req")]([SubResource("Requirement")])
wheel_definition = SubResource("WheelDefinition")
